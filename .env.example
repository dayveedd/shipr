MONNIFY_GLOBAL_BANK_CODE=your_escrow_bank_code_here
MONNIFY_GLOBAL_BANK_NAME=your_escrow_bank_name_here
MONNIFY_GLOBAL_ACCOUNT_NUMBER=your_escrow_account_number_here

# OpenRouter AI Judge Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
